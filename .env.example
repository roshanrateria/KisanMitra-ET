# KisanMitra Environment Configuration
# FRONTEND ONLY — No API keys here!
# All API keys are stored in Lambda environment variables.

# =====================================================
# Auth0 Configuration (client-side config — NOT a secret)
# =====================================================
VITE_AUTH0_DOMAIN=your-auth0-domain.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# =====================================================
# API Server URL (Lambda + API Gateway endpoint)
# =====================================================
# Set this after deploying the Lambda server
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/prod
VITE_API_URL=

# =====================================================
# SERVER-SIDE KEYS (set as Lambda environment variables)
# Do NOT put these here — set them in Lambda config
# =====================================================
# GROQ_API_KEY=your_groq_api_key
# GEMINI_API_KEY=your_gemini_api_key
# OPENWEATHER_API_KEY=your_openweather_api_key
# BHASHINI_API_KEY=your_bhashini_ulca_key
# BHASHINI_USER_ID=your_bhashini_user_id
# DISEASE_DETECTION_ENDPOINT=your_huggingface_endpoint
# HUGGINGFACE_API_KEY=your_huggingface_api_key

# =====================================================
# ONDC Configuration (server-side)
# =====================================================
# ONDC_GATEWAY_URL=https://staging.gateway.proteantech.in
# ONDC_MOCK_URL=your-ondc-mock-url
# BAP_ID=your-bap-id
# BAP_URI=your-bap-uri
